#!/usr/bin/env perl

use strict;
use warnings;

use English qw(-no_match_vars);
use Data::Dumper;

########################################################################
sub main {
########################################################################

  my ($lambda) = @_;

  $lambda = eval {
    if ( !$lambda ) {
      $lambda = $ENV{_HANDLER} // q{};

      die "ERROR: usage: plambda.pl module-name\n"
        if !$lambda;

      ($lambda) = split /[.]/xsm, $lambda;
    }

    require "$lambda.pm";

    return $lambda;
  };

  if ( !$lambda || $EVAL_ERROR ) {
    print {*STDERR} "ERROR: Could not initialize runtime\n$EVAL_ERROR\n";
    print {*STDERR} Dumper( [ env => \%ENV ] );
    return 1;
  }

  return $lambda->new->run;
}

exit main(@ARGV);

1;

__END__

=pod

=head1 NAME

plambda.pl

=head1 SYNOPSIS

 plambda.pl $module

=head1 DESCRIPTION

Stub driver that invokes your AWS Lambda method.  Part of the Perl
Lambda Runtime system.

=head1 AUTHOR

Rob Lauer - <rlauer@treasurersbriefcase.com>

=cut
